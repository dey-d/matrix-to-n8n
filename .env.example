# Matrix homeserver and account details
MATRIX_HOMESERVER_URL=https://matrix.com # change to self hsoted Matrix URL
MATRIX_ROOM_ID=enter-matrix-room-ID" # usally like !txxxxxxxxxxxxx:matrix
MATRIX_USER_ID=@bot:matrix # setup as per bot username 
MATRIX_PASSWORD=change-me

# Optional: use an access token instead of password after first login
MATRIX_ACCESS_TOKEN=
MATRIX_DEVICE_NAME=matrix-to-n8n

# n8n webhook destination
N8N_WEBHOOK_URL=enter-webhook-url-here

# Runtime / safety tuning
MATRIX_STATE_DIR=/data
MATRIX_SYNC_TIMEOUT_MS=30000
MATRIX_FORWARD_OWN_MESSAGES=false
MATRIX_MAX_SEEN_EVENTS=2000
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=5
WEBHOOK_BACKOFF_INITIAL_SECONDS=1
WEBHOOK_BACKOFF_MAX_SECONDS=30
LOG_LEVEL=INFO
